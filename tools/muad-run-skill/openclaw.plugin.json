{
  "id": "muad-run-skill",
  "name": "Muad Run Skill",
  "description": "Runs Muad script skills and forwards progress through OpenClaw tool updates.",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": [
      "muad_use_skill",
      "muad_run_skill"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "skillsRoot": {
        "type": "string"
      },
      "privateRoot": {
        "type": "string"
      },
      "maxConcurrency": {
        "type": "integer",
        "minimum": 1
      },
      "queueTimeoutMs": {
        "type": "integer",
        "minimum": 1
      },
      "maxQueue": {
        "type": "integer",
        "minimum": 1
      },
      "skillPolicies": {
        "type": "array"
      },
      "activation": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "toolName": { "type": "string" },
          "requireBeforeExecution": { "type": "boolean" },
          "detectSkillFileReads": { "type": "boolean" },
          "contextTimeoutMs": { "type": "integer", "minimum": 1 },
          "cleanupIntervalMs": { "type": "integer", "minimum": 1 }
        }
      },
      "telemetry": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "consoleInternalURL": { "type": "string" },
          "serviceTokenFile": { "type": "string" },
          "outboxPath": { "type": "string" },
          "maxQueueItems": { "type": "integer", "minimum": 1 },
          "maxOutboxBytes": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
