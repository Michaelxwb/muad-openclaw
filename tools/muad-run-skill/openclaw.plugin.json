{
  "id": "muad-run-skill",
  "name": "Muad Run Skill",
  "description": "Runs Muad script skills and forwards progress through OpenClaw tool updates.",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": [
      "muad_run_skill"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "skillsRoot": {
        "type": "string"
      },
      "maxConcurrency": {
        "type": "integer",
        "minimum": 1
      },
      "queueTimeoutMs": {
        "type": "integer",
        "minimum": 1
      },
      "maxQueue": {
        "type": "integer",
        "minimum": 1
      },
      "skillPolicies": {
        "type": "array"
      },
      "consoleInternalURL": {
        "type": "string"
      },
      "serviceTokenFile": {
        "type": "string"
      }
    }
  }
}
