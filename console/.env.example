# 复制为 .env 后填写；docker compose 自动加载。凭证绝不入库。

# AES-GCM 主密钥（加密 DB 内 bot secret / LLM key）。生成：openssl rand -hex 32
CONSOLE_MASTER_KEY=

# 初始管理员密码（首启幂等引导；用户名默认 admin）
CONSOLE_ADMIN_PASSWORD=

# 可选覆盖：
# CONSOLE_ADMIN_USER=admin
# CONSOLE_PORT=8080
# 控制台镜像（默认 latest；验证特定版本用 :0.1.0）
# MUAD_CONSOLE_IMAGE=ghcr.io/michaelxwb/muad-console:0.1.0
# 新建用户容器默认 worker 镜像
# MUAD_OC_IMAGE=ghcr.io/michaelxwb/muad-openclaw:0.1.0
# 共享 skill 目录（宿主机绝对路径）
# SKILLS_DIR=/opt/muad/skills
