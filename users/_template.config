# 每用户外部配置（管理员只填这个文件）。
# 用法：cp users/_template.config users/<userId>/config && 编辑 && ./provision-user.sh <userId>
# 含密钥，权限自动设 600，勿提交 git。

# 企微智能机器人（每用户独立 bot）
WECOM_BOT_ID=
WECOM_SECRET=

# LLM（OpenAI 兼容端点）
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_MODEL=deepseek-v4-pro
LLM_BASE_URL=https://api.deepseek.com
